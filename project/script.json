  /* ----------------------------------------------------------
     4. NAVBAR (scroll state + active link + mobile menu)
     ---------------------------------------------------------- */

  function initNavbar() {
    const navbar = $("#navbar");
    const menuToggle = $("#menuToggle");
    const navLinks = $("#navLinks");
    const links = $$(".nav-link");

    window.addEventListener("scroll", () => {
      navbar.classList.toggle("scrolled", window.scrollY > 40);
    });

    menuToggle.addEventListener("click", () => {
      navLinks.classList.toggle("open");
      const open = navLinks.classList.contains("open");
      menuToggle.innerHTML = open
        ? '<i class="fa-solid fa-xmark"></i>'
        : '<i class="fa-solid fa-bars"></i>';
    });

    links.forEach((link) => {
      link.addEventListener("click", () => {
        navLinks.classList.remove("open");
        menuToggle.innerHTML = '<i class="fa-solid fa-bars"></i>';
      });
    });

    // Active link on scroll (section observer)
    const sections = $$("section[id]");
    const linkMap = {};
    links.forEach((l) => (linkMap[l.getAttribute("href").slice(1)] = l));

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove("active"));
            const active = linkMap[entry.target.id];
            if (active) active.classList.add("active");
          }
        });
      },
      { rootMargin: "-45% 0px -50% 0px" }
    );
    sections.forEach((s) => sectionObserver.observe(s));
  }

  /* ----------------------------------------------------------
     5. REVEAL ON SCROLL
     ---------------------------------------------------------- */

  function initReveal() {
    const revealEls = $$(".reveal");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    revealEls.forEach((el) => io.observe(el));
  }

  /* ----------------------------------------------------------
     6. ANIMATED COUNTERS
     ---------------------------------------------------------- */

  function initCounters() {
    const counters = $$(".stat-number");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const target = +el.dataset.target;
          const duration = 1800;
          const start = performance.now();
          const fmt = (n) =>
            target >= 1000 ? Math.round(n).toLocaleString() : Math.round(n);

          function tick(now) {
            const p = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
            el.textContent = fmt(target * eased);
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = fmt(target);
          }
          requestAnimationFrame(tick);
          io.unobserve(el);
        });
      },
      { threshold: 0.5 }
    );
    counters.forEach((c) => io.observe(c));
  }

  /* ----------------------------------------------------------
     7. DARK MODE TOGGLE
     ---------------------------------------------------------- */

  function initTheme() {
    const toggle = $("#themeToggle");
    const saved = localStorage.getItem("mt-theme");
    if (saved) document.documentElement.setAttribute("data-theme", saved);
    updateIcon();

    toggle.addEventListener("click", () => {
      const dark = document.documentElement.getAttribute("data-theme") === "dark";
      if (dark) document.documentElement.removeAttribute("data-theme");
      else document.documentElement.setAttribute("data-theme", "dark");
      localStorage.setItem("mt-theme", dark ? "light" : "dark");
      updateIcon();
    });

    function updateIcon() {
      const dark = document.documentElement.getAttribute("data-theme") === "dark";
      toggle.innerHTML = dark
        ? '<i class="fa-solid fa-sun"></i>'
        : '<i class="fa-solid fa-moon"></i>';
    }
  }

  /* ----------------------------------------------------------
     8. METRO ROUTE PLANNER
     ---------------------------------------------------------- */

  function initMetroPlanner() {
    const btn = $("#metroRouteBtn");
    const source = $("#sourceStation");
    const dest = $("#destStation");
    const timeEl = $("#metroTime");
    const stopsEl = $("#metroStops");

    btn.addEventListener("click", () => {
      if (!source.value || !dest.value) {
        showToast("Please select both stations", "warn");
        return;
      }
      if (source.value === dest.value) {
        showToast("Source and destination are the same", "warn");
        return;
      }
      // Simulated route calculation
      const stations = ["Central", "Riverside", "Plaza", "Harbor", "Old Town"];
      const s = stations.indexOf(source.value);
      const d = stations.indexOf(dest.value);
      const stops = Math.abs(d - s) + 1;
      const minutes = stops * 6 + 4;
      timeEl.textContent = minutes + " min";
      stopsEl.textContent = stops + " stops";
      showToast("Route found: " + source.value + " → " + dest.value);
    });
  }

  /* ----------------------------------------------------------
     9. AUTH MODAL
     ---------------------------------------------------------- */

  function initModal() {
    const overlay = $("#authModal");
    const closeBtn = $("#modalClose");
    const switchBtn = $("#modalSwitchBtn");
    const title = $("#modalTitle");
    const subtitle = $("#modalSubtitle");
    const nameField = $("#nameField");
    const submit = $("#authSubmit");
    const switchText = $("#modalSwitchText");
    let mode = "login";

    function openModal(target) {
      mode = target === "register" ? "register" : "login";
      updateModal();
      overlay.classList.add("open");
      overlay.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      overlay.classList.remove("open");
      overlay.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }

    function updateModal() {
      if (mode === "register") {
        title.textContent = "Create Account";
        subtitle.textContent = "Join MetroTour Explorer to start your journey.";
        nameField.hidden = false;
        submit.textContent = "Register";
        switchText.textContent = "Already have an account?";
        switchBtn.textContent = "Login";
      } else {
        title.textContent = "Login";
        subtitle.textContent = "Welcome back. Please sign in to continue.";
        nameField.hidden = true;
        submit.textContent = "Login";
        switchText.textContent = "Don't have an account?";
        switchBtn.textContent = "Register";
      }
    }

    $$("[data-open-modal]").forEach((btn) =>
      btn.addEventListener("click", () => openModal(btn.dataset.openModal))
    );

    closeBtn.addEventListener("click", closeModal);
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeModal();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && overlay.classList.contains("open")) closeModal();
    });

    switchBtn.addEventListener("click", () => {
      mode = mode === "login" ? "register" : "login";
      updateModal();
    });

    $("#authForm").addEventListener("submit", (e) => {
      e.preventDefault();
      showToast(mode === "login" ? "Login successful!" : "Account created!");
      closeModal();
      e.target.reset();
    });
  }

  /* ----------------------------------------------------------
     10. RIPPLE EFFECT
     ---------------------------------------------------------- */

  function initRipple() {
    document.addEventListener("click", (e) => {
      const btn = e.target.closest(".ripple");
      if (!btn) return;
      const rect = btn.getBoundingClientRect();
      const size = Math.max(rect.width, rect.height);
      const circle = document.createElement("span");
      circle.className = "ripple-circle";
      circle.style.width = circle.style.height = size + "px";
      circle.style.left = e.clientX - rect.left - size / 2 + "px";
      circle.style.top = e.clientY - rect.top - size / 2 + "px";
      btn.appendChild(circle);
      setTimeout(() => circle.remove(), 600);
    });
  }

  /* ----------------------------------------------------------
     11. BACK TO TOP
     ---------------------------------------------------------- */

  function initBackToTop() {
    const btn = $("#backToTop");
    window.addEventListener("scroll", () => {
      btn.classList.toggle("show", window.scrollY > 500);
    });
    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  /* ----------------------------------------------------------
     12. SEARCH + NEWSLETTER + BOOKING (demo handlers)
     ---------------------------------------------------------- */

  function initForms() {
    $("#searchForm").addEventListener("submit", (e) => {
      e.preventDefault();
      const dest = $("#searchDest").value.trim() || "all destinations";
      showToast("Searching " + dest + "…");
    });

    $("#newsletterForm").addEventListener("submit", (e) => {
      e.preventDefault();
      showToast("Subscribed! Watch your inbox for travel deals.");
      e.target.reset();
    });

    // Delegated booking buttons
    document.addEventListener("click", (e) => {
      const hotel = e.target.closest(".book-hotel");
      const event = e.target.closest(".book-event");
      if (hotel) showToast("Booking: " + hotel.dataset.hotel);
      if (event) showToast("Ticket reserved: " + event.dataset.event);
    });
  }

  /* ----------------------------------------------------------
     13. TOAST
     ---------------------------------------------------------- */

  let toastTimer;
  function showToast(msg, type) {
    let toast = $(".toast");
    if (!toast) {
      toast = document.createElement("div");
      toast.className = "toast";
      document.body.appendChild(toast);
    }
    const icon =
      type === "warn"
        ? '<i class="fa-solid fa-circle-exclamation" style="color:#f59e0b"></i>'
        : '<i class="fa-solid fa-circle-check"></i>';
    toast.innerHTML = icon + " " + msg;
    toast.classList.add("show");
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove("show"), 2800);
  }

  /* ----------------------------------------------------------
     14. MISC
     ---------------------------------------------------------- */

  function initYear() {
    $("#year").textContent = new Date().getFullYear();
  }

  /* ----------------------------------------------------------
     INIT
     ---------------------------------------------------------- */

  document.addEventListener("DOMContentLoaded", () => {
    renderDestinations();
    renderHotels();
    renderEvents();
    renderFeatures();
    renderTestimonials();
    initNavbar();
    initReveal();
    initCounters();
    initTheme();
    initMetroPlanner();
    initModal();
    initRipple();
    initBackToTop();
    initForms();
    initYear();
  });
})();

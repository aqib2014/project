        <div class="tour-card-img">
          <img src="${d.img}" alt="${d.name}" loading="lazy" />
          <span class="tour-card-badge">${d.badge}</span>
          <button class="tour-card-fav" aria-label="Save ${d.name}">
            <i class="fa-regular fa-heart"></i>
          </button>
        </div>
        <div class="tour-card-body">
          <h3 class="tour-card-title">${d.name}</h3>
          <div class="tour-card-meta">
            <i class="fa-solid fa-train-subway"></i> ${d.station}
          </div>
          <div class="tour-card-rating">
            <span class="stars">${starHTML(d.rating)}</span>
            <span>${d.rating}</span>
          </div>
          <div class="tour-card-footer">
            <span class="tour-card-price">$${d.price}<span> / person</span></span>
            <a href="#metro" class="tour-card-btn">Explore <i class="fa-solid fa-arrow-right"></i></a>
          </div>
        </div>
      </article>`
      )
      .join("");
  }

